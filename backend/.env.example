# AI Provider Configuration (OpenAI-compatible APIs)
# Use any OpenAI-compatible provider: OpenAI, Anthropic, GLM, or custom
AI_PROVIDER=glm
AI_API_KEY=your_api_key_here
AI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
AI_MODEL=glm-4

# For custom provider, set AI_PROVIDER=custom and specify your own API endpoint
# Example for Z.ai with GLM-4.7:
# AI_PROVIDER=custom
# AI_API_KEY=your_z_ai_api_key
# AI_BASE_URL=https://api.z.ai/v1
# AI_MODEL=glm-4.7

# Server Configuration
PORT=8000
DEVICE_NAME=My Device
DEVICE_MODE=primary
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8000

# File Scan Configuration
SCAN_PATHS=~/Documents,~/Downloads,~/Desktop
MAX_INDEX_SIZE=100000
EXCLUDE_DIRS=.git,node_modules,__pycache__,.venv,venv,.idea,.vscode

# Discovery Configuration
DISCOVERY_PORT=8001
HEARTBEAT_INTERVAL=30
HEARTBEAT_TIMEOUT=120

# Encryption Configuration (for API keys)
# IMPORTANT: Generate a unique key for production!
# Run: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# The same key must be used for both encryption and decryption of API keys stored in the database.
ENCRYPTION_KEY=
