# GLM API Configuration
GLM_API_KEY=your_glm_api_key_here
GLM_API_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
GLM_MODEL=glm-4-flash

# Server Configuration
PORT=8000
DEVICE_NAME=My Device
DEVICE_MODE=primary
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8000

# File Scan Configuration
SCAN_PATHS=~/Documents,~/Downloads,~/Desktop
MAX_INDEX_SIZE=100000
EXCLUDE_DIRS=.git,node_modules,__pycache__,.venv,venv,.idea,.vscode

# Discovery Configuration
DISCOVERY_PORT=8001
HEARTBEAT_INTERVAL=30
HEARTBEAT_TIMEOUT=120
