# Frontend Development Dockerfile (React with Vite - Hot Reload)
FROM node:20-alpine

WORKDIR /app

# Copy package files
COPY package*.json ./

# Install dependencies
RUN npm install

# Copy source code
COPY . .

# Expose Vite dev server port on all interfaces
EXPOSE 5173

# Run Vite dev server with hot reload (host 0.0.0.0 for external access)
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
